{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "thinking-proxy.error.invalid-request": {
      "comment": "Error message when request data cannot be decoded",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitud inválida"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的请求"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Requête invalide"
          }
        }
      }
    },
    "thinking-proxy.error.invalid-request-line": {
      "comment": "Error message when HTTP request line is missing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request line"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Línea de solicitud inválida"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的请求行"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligne de requête non valide"
          }
        }
      }
    },
    "thinking-proxy.error.invalid-request-format": {
      "comment": "Error message when HTTP request format is malformed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request format"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato de solicitud inválido"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的请求格式"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide"
          }
        }
      }
    },
    "thinking-proxy.error.no-body-separator": {
      "comment": "Error message when HTTP request is missing header/body separator",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request format - no body separator"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato de solicitud inválido - sin separador de cuerpo"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "请求格式无效 - 缺少正文分隔符"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide - aucun séparateur de corps"
          }
        }
      }
    },
    "thinking-proxy.error.ampcode-connection": {
      "comment": "Error message when connection to ampcode.com fails",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bad Gateway - Could not connect to ampcode.com"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Puerta de enlace incorrecta - No se pudo conectar a ampcode.com"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "网关错误 - 无法连接到 ampcode.com"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Passerelle incorrecte - Impossible de se connecter à ampcode.com"
          }
        }
      }
    },
