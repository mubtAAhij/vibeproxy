    "auth.copilot.code-extracted": {
      "comment": "Success message when GitHub Copilot device code is extracted and copied to clipboard",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\n📋 Code copied to clipboard:\\n\\n%@\\n\\nJust paste it in the browser!\\n\\nThe app will automatically detect when you're authenticated."
          }
        }
      }
    },
    "auth.copilot.code-not-extracted": {
      "comment": "Fallback message when GitHub Copilot device code cannot be extracted automatically",
