{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "proxy.error.invalid-request": {
      "comment": "HTTP error when request data is not valid UTF-8",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitud inválida"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的请求"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Requête invalide"
          }
        }
      }
    },
    "proxy.error.invalid-request-line": {
      "comment": "HTTP error when request line is missing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
