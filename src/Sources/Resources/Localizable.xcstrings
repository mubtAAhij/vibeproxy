            "state": "translated",
            "value": "Impossible de trouver le chemin de la ressource"
          }
        }
      }
    },
    "server.error.binary-not-found": {
      "comment": "Error when CLI binary is missing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Binary not found at %@"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
