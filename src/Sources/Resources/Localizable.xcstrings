            "state": "translated",
            "value": "Puerta de enlace incorrecta - No se pudo conectar a ampcode.com"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "网关错误 - 无法连接到 ampcode.com"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mauvaise passerelle - Impossible de se connecter à ampcode.com"
          }
        }
      }
    },
