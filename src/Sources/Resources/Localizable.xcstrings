        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato de solicitud inválido - sin separador de cuerpo"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的请求格式 - 缺少正文分隔符"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide - aucun séparateur de corps"
          }
        }
      }
    },
    "proxy.error.ampcode-connection-failed": {
      "comment": "Error when connection to ampcode.com fails",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bad Gateway - Could not connect to ampcode.com"
