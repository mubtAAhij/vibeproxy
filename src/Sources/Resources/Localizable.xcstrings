        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Z.AI GLM donne accès à GLM-4.7 et d'autres modèles via une clé API. Obtenez votre clé sur https://z.ai/manage-apikey/apikey-list"
          }
        }
      }
