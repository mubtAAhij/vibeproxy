    "settings.vercel.toggle": {
      "comment": "Toggle to enable Vercel AI Gateway for Claude requests",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use Vercel AI Gateway"
