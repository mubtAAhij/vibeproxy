    "auth.error.no-output": {
      "comment": "Error when auth has no output",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No output from authentication process"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "La autenticación falló. Por favor verifica si el navegador se abrió e intenta nuevamente.\\n\\nDetalles: \\(output.isEmpty ? \\\"No hay información del proceso de autenticación\\\" : output)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证失败。请检查浏览器是否已打开，然后重试。\\n\\n详细信息：\\(output.isEmpty ? \\\"身份验证进程无输出\\\" : output)"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "L'authentification a échoué. Veuillez vérifier que le navigateur s'est ouvert et réessayer.\\n\\nDétails : \\(output.isEmpty ? \\\"Aucune sortie du processus d'authentification\\\" : output)"
          }
        }
      }
    },
    "auth.success.claude": {
      "comment": "Success message for Claude auth",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
