    "auth.github.code-copied": {
      "comment": "Success message when GitHub device code is copied",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\n📋 Code copied to clipboard:\\n\\n%@\\n\\nJust paste it in the browser!\\n\\nThe app will automatically detect when you're authenticated."
          }
        }
      }
    },
    "auth.github.browser-opened-check-terminal": {
      "comment": "Fallback message when device code cannot be extracted",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\nCheck your terminal or the opened browser for the device code.\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Se abrió el navegador para la autenticación de GitHub.\\n\\nRevisa tu terminal o el navegador abierto para ver el código del dispositivo.\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\\n\\n请在终端或已打开的浏览器中查看设备代码。\\n\\n应用将自动检测您的身份验证状态。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\\n\\nConsultez votre terminal ou le navigateur ouvert pour obtenir le code de l'appareil.\\n\\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "auth.browser-opened": {
      "comment": "Generic success message when browser opens for auth",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for authentication.\\n\\nPlease complete the login in your browser.\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Se abrió el navegador para la autenticación.\\n\\nPor favor completa el inicio de sesión en tu navegador.\\n\\nLa aplicación detectará automáticamente cuando estés autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行身份验证。\\n\\n请在浏览器中完成登录。\\n\\n应用会自动检测您的验证状态。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Le navigateur s'est ouvert pour l'authentification.\\n\\nVeuillez finaliser la connexion dans votre navigateur.\\n\\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "auth.error.process-failed": {
      "comment": "Error when auth process fails without details",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentication process failed unexpectedly"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El proceso de autenticación falló inesperadamente"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证过程意外失败"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le processus d'authentification a échoué de manière inattendue"
          }
        }
      }
    },
