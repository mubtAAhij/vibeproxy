        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 Vercel AI Gateway 转发 Claude 请求，以更安全地访问您的 Claude Max 订阅"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acheminez les requêtes Claude via Vercel AI Gateway pour un accès plus sécurisé à votre abonnement Claude Max"
          }
        }
      }
    },
