            "state": "translated",
            "value": "找不到资源路径"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de trouver le chemin de ressource"
          }
        }
      }
    },
    "server.error.binary-not-found": {
      "comment": "Error when bundled binary is missing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Binary not found at %@"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Binario no encontrado en \\(bundledPath)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到二进制文件：\\(bundledPath)"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Binaire introuvable à \\(bundledPath)"
          }
        }
      }
    },
    "auth.github.code-copied": {
      "comment": "Success message when GitHub auth code is copied to clipboard",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\n📋 Code copied to clipboard:\\n\\n%@\\n\\nJust paste it in the browser!\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\\n\\n📋 Código copiado al portapapeles:\\n\\n\\(code)\\n\\n¡Solo pégalo en el navegador!\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\\n\\n📋 代码已复制到剪贴板：\\n\\n\\(code)\\n\\n只需将其粘贴到浏览器中即可！\\n\\n应用将自动检测您的身份验证状态。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\\n\\n📋 Code copié dans le presse-papiers :\\n\\n\\(code)\\n\\nCollez-le simplement dans le navigateur !\\n\\nL'application détectera automatiquement quand vous serez authentifié."
          }
        }
      }
    },
    "auth.github.check-browser": {
      "comment": "Message when GitHub auth is started but code extraction failed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\nCheck your terminal or the opened browser for the device code.\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\\n\\nRevisa tu terminal o el navegador abierto para ver el código de dispositivo.\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\\n\\n请在终端或已打开的浏览器中查看设备代码。\\n\\n应用将自动检测您的身份验证状态。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\\n\\nVérifiez votre terminal ou le navigateur ouvert pour le code d'appareil.\\n\\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "auth.browser-opened": {
      "comment": "Generic message when authentication browser opens",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for authentication.\\n\\nPlease complete the login in your browser.\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación.\\n\\nPor favor completa el inicio de sesión en tu navegador.\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行身份验证。\\n\\n请在浏览器中完成登录。\\n\\n应用将自动检测您的登录状态。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification.\\n\\nVeuillez terminer la connexion dans votre navigateur.\\n\\nL'application détectera automatiquement lorsque vous serez authentifié(e)."
          }
        }
      }
    },
    "auth.error.process-failed": {
      "comment": "Error when auth process fails without output",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentication process failed unexpectedly"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
