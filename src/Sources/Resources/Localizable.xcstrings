{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "proxy.error.invalid-request": {
      "comment": "HTTP 400 error when request data is not valid UTF-8",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitud inválida"
          }
        }
      }
    },
    "proxy.error.invalid-request-line": {
      "comment": "HTTP 400 error when request line is missing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request line"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Línea de solicitud inválida"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligne de requête invalide"
          }
        }
      }
    },
    "proxy.error.invalid-request-format": {
      "comment": "HTTP 400 error when request format is malformed",
      "extractionState": "manual",
      "localizations": {
