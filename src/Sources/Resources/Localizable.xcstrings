    "settings.vercel.use-gateway.help": {
      "comment": "Help text for Vercel AI Gateway toggle",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Route Claude requests through Vercel AI Gateway for safer access to your Claude Max subscription"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Enruta las solicitudes de Claude a través de Vercel AI Gateway para un acceso más seguro a tu suscripción de Claude Max"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 Vercel AI Gateway 路由 Claude 请求，以更安全地访问您的 Claude Max 订阅"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acheminez les requêtes Claude via Vercel AI Gateway pour un accès plus sécurisé à votre abonnement Claude Max"
          }
        }
      }
    },
