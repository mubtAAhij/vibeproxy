            "value": "No se pudo encontrar la ruta del recurso"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Chemin de la ressource introuvable"
          }
        }
      }
    },
    "server.error.binary-not-found": {
      "comment": "Error when binary is missing at path",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Binary not found at %@"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Binario no encontrado en %@"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "未在 %@ 找到二进制文件"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Binaire introuvable à %@"
          }
        }
      }
    },
    "auth.github.code-copied": {
      "comment": "GitHub auth success with device code copied",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\n📋 Code copied to clipboard:\\n\\n%@\\n\\nJust paste it in the browser!\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Se abrió el navegador para autenticación de GitHub.\\n\\n📋 Código copiado al portapapeles:\\n\\n%@\\n\\n¡Solo pégalo en el navegador!\\n\\nLa app detectará automáticamente cuando estés autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 认证。\\n\\n📋 验证码已复制到剪贴板：\\n\\n%@\\n\\n请在浏览器中粘贴！\\n\\n应用将自动检测认证完成。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\\n\\n📋 Code copié dans le presse-papiers :\\n\\n%@\\n\\nCollez-le simplement dans le navigateur !\\n\\nL'application détectera automatiquement votre authentification."
          }
        }
      }
    },
    "auth.github.no-code": {
      "comment": "GitHub auth fallback message when device code cannot be extracted",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\nCheck your terminal or the opened browser for the device code.\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Le navigateur s'est ouvert pour l'authentification GitHub.\\n\\nConsultez votre terminal ou le navigateur ouvert pour le code d'appareil.\\n\\nL'application détectera automatiquement votre authentification."
          }
        }
      }
    },
    "auth.browser-opened": {
      "comment": "Generic auth success message when browser opens",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for authentication.\\n\\nPlease complete the login in your browser.\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Se abrió el navegador para autenticación.\\n\\nPor favor complete el inicio de sesión en su navegador.\\n\\nLa aplicación detectará automáticamente cuando esté autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行身份验证。\\n\\n请在浏览器中完成登录。\\n\\n应用将自动检测您的身份验证状态。"
          }
        }
      }
    },
    "auth.error.unexpected": {
      "comment": "Error when auth process fails without output",
      "extractionState": "manual",
      "localizations": {
