    "settings.provider.account-count": {
      "comment": "Shows number of connected accounts",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d connected account%@"
          },
          "variations": {
            "quantity": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%d connected account"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%d connected accounts"
                }
              }
            }
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "\\(accounts.count) cuenta\\(accounts.count == 1 ? \\\"\\\" : \\\"s\\\") conectada\\(accounts.count == 1 ? \\\"\\\" : \\\"s\\\")"
          },
          "variations": {
            "quantity": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\\(accounts.count) cuenta\\(accounts.count == 1 ? \\\"\\\" : \\\"s\\\") conectada\\(accounts.count == 1 ? \\\"\\\" : \\\"s\\\")"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\\(accounts.count) cuenta\\(accounts.count == 1 ? \\\"\\\" : \\\"s\\\") conectada\\(accounts.count == 1 ? \\\"\\\" : \\\"s\\\")"
                }
              }
            }
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "\\(accounts.count) 个已连接账户"
          },
          "variations": {
            "quantity": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\\(accounts.count) 个已连接账户"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\\(accounts.count) 个已连接账户"
                }
              }
            }
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "\\(accounts.count) compte\\(accounts.count == 1 ? \\\" connecté\\\" : \\\"s connectés\\\")"
          },
          "variations": {
            "quantity": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\\(accounts.count) compte\\(accounts.count == 1 ? \\\" connecté\\\" : \\\"s connectés\\\")"
                }
              },
