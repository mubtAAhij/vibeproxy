    },
    "proxy.error.invalid-request-no-body-separator": {
      "comment": "Error when HTTP request is missing body separator",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request format - no body separator"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato de solicitud inválido - sin separador de cuerpo"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "请求格式无效 - 缺少正文分隔符"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide - aucun séparateur de corps"
          }
        }
      }
    },
    "proxy.error.ampcode-connection-failed": {
      "comment": "Error when connection to ampcode.com fails",
      "extractionState": "manual",
