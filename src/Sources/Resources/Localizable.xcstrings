    "settings.services.gemini.help": {
      "comment": "Help text for Gemini service with multi-project warning",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Note: If you're an existing Gemini user with multiple projects, authentication will use your default project. Set your desired project as default in Google AI Studio before connecting."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Nota: Si eres un usuario existente de Gemini con múltiples proyectos, la autenticación usará tu proyecto predeterminado. Establece el proyecto deseado como predeterminado en Google AI Studio antes de conectarte."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 注意：如果您是拥有多个项目的现有 Gemini 用户,身份验证将使用您的默认项目。请在连接之前于 Google AI Studio 中将所需项目设置为默认项目。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Remarque : Si vous êtes un utilisateur Gemini existant avec plusieurs projets, l'authentification utilisera votre projet par défaut. Définissez le projet souhaité comme projet par défaut dans Google AI Studio avant de vous connecter."
          }
        }
      }
    },
    "settings.services.copilot.help": {
      "comment": "Help text for GitHub Copilot service",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Copilot provides access to Claude, GPT, Gemini and other models via your Copilot subscription."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Copilot brinda acceso a Claude, GPT, Gemini y otros modelos a través de tu suscripción a Copilot."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Copilot 通过您的 Copilot 订阅提供对 Claude、GPT、Gemini 及其他模型的访问。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Copilot donne accès à Claude, GPT, Gemini et d'autres modèles via votre abonnement Copilot."
          }
        }
      }
    },
    "settings.services.zai.help": {
      "comment": "Help text for Z.AI service",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Z.AI GLM provides access to GLM-4.7 and other models via API key. Get your key at https://z.ai/manage-apikey/apikey-list"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Z.AI GLM proporciona acceso a GLM-4.7 y otros modelos mediante clave API. Obtén tu clave en https://z.ai/manage-apikey/apikey-list"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Z.AI GLM 通过 API 密钥提供 GLM-4.7 及其他模型的访问权限。请在 https://z.ai/manage-apikey/apikey-list 获取您的密钥"
