    "proxy.error.ampcode-connection-failed": {
      "comment": "HTTP 502 error when ampcode.com is unreachable",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bad Gateway - Could not connect to ampcode.com"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Puerta de enlace incorrecta - No se pudo conectar a ampcode.com"
          }
        },
