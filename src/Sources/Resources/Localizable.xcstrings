            "value": "Formato de solicitud inválido"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "请求格式无效"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide"
          }
        }
      }
    },
    "proxy.error.no-body-separator": {
      "comment": "HTTP error when request is missing body separator",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request format - no body separator"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato de solicitud inválido - sin separador de cuerpo"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "请求格式无效 - 缺少正文分隔符"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide - aucun séparateur de corps"
          }
        }
      }
    },
    "proxy.error.ampcode-gateway": {
      "comment": "HTTP error when proxy cannot reach ampcode.com",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bad Gateway - Could not connect to ampcode.com"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Puerta de enlace incorrecta - No se pudo conectar a ampcode.com"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "网关错误 - 无法连接到 ampcode.com"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Passerelle incorrecte - Impossible de se connecter à ampcode.com"
          }
        }
      }
    },
