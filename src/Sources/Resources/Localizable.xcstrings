          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "启动身份验证流程失败：\\(error.localizedDescription)"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec du démarrage du processus d'authentification : %@"
          }
