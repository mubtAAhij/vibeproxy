{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "proxy.error.invalid-request": {
      "comment": "Error when request data is not valid UTF-8",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitud inválida"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效请求"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Requête invalide"
          }
        }
      }
    },
    "proxy.error.invalid-request-line": {
      "comment": "Error when HTTP request line is missing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request line"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
