    "server.auth.github-code-copied": {
      "comment": "GitHub auth success with code copied",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\n📋 Code copied to clipboard:\\n\\n%@\\n\\nJust paste it in the browser!\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\\n\\n📋 Código copiado al portapapeles:\\n\\n\\(code)\\n\\n¡Solo pégalo en el navegador!\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\\n\\n📋 代码已复制到剪贴板：\\n\\n\\(code)\\n\\n请在浏览器中粘贴！\\n\\n应用将自动检测您的登录状态。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\\n\\n📋 Code copié dans le presse-papiers :\\n\\n\\(code)\\n\\nCollez-le simplement dans le navigateur !\\n\\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "server.auth.github-check-browser": {
      "comment": "GitHub auth success without code extraction",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\nCheck your terminal or the opened browser for the device code.\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\\n\\nVerifica tu terminal o el navegador abierto para ver el código del dispositivo.\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\\n\\n请在终端或打开的浏览器中查看设备代码。\\n\\n应用程序将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\\n\\nConsultez votre terminal ou le navigateur ouvert pour obtenir le code de l'appareil.\\n\\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "server.auth.browser-opened": {
      "comment": "Generic auth success message",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for authentication.\\n\\nPlease complete the login in your browser.\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación.\\n\\nPor favor completa el inicio de sesión en tu navegador.\\n\\nLa aplicación detectará automáticamente cuando estés autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行身份验证。\\n\\n请在浏览器中完成登录。\\n\\n应用将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification.\\n\\nVeuillez vous connecter dans votre navigateur.\\n\\nL'application détectera automatiquement votre authentification."
          }
        }
      }
    },
    "server.auth.failed-unexpectedly": {
      "comment": "Error when auth process fails without output",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentication process failed unexpectedly"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El proceso de autenticación falló inesperadamente"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证过程意外失败"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le processus d'authentification a échoué de manière inattendue"
          }
        }
      }
    },
    "server.auth.failed-to-start": {
      "comment": "Error when auth process fails to start",
      "extractionState": "manual",
      "localizations": {
