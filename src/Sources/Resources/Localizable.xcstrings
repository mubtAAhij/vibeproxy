    "auth.copilot.success-with-code": {
      "comment": "Success message when GitHub Copilot auth starts with code",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\n\n📋 Code copied to clipboard:\n\n%@\n\nJust paste it in the browser!\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\n\n📋 Código copiado al portapapeles:\n\n%@\n\n¡Solo pégalo en el navegador!\n\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\n\n📋 代码已复制到剪贴板:\n\n%@\n\n直接粘贴到浏览器即可!\n\n应用会自动检测您的身份验证状态。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\n\n📋 Code copié dans le presse-papiers :\n\n%@\n\nIl suffit de le coller dans le navigateur !\n\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "auth.copilot.success-no-code": {
      "comment": "Success message when GitHub Copilot auth starts without code extraction",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\n\nCheck your terminal or the opened browser for the device code.\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\n\nRevisa tu terminal o el navegador abierto para ver el código de dispositivo.\n\nLa aplicación detectará automáticamente cuando estés autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\n\n请在终端或已打开的浏览器中查看设备代码。\n\n应用将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\n\nConsultez votre terminal ou le navigateur ouvert pour obtenir le code d'appareil.\n\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "auth.generic.success": {
      "comment": "Generic success message when authentication browser opens",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for authentication.\n\nPlease complete the login in your browser.\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación.\n\nPor favor completa el inicio de sesión en tu navegador.\n\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行身份验证。\n\n请在浏览器中完成登录。\n\n应用程序将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification.\n\nVeuillez vous connecter dans votre navigateur.\n\nL'application détectera automatiquement votre authentification."
          }
        }
      }
    },
    "auth.error.unexpected-failure": {
      "comment": "Error when authentication fails with no error output",
      "extractionState": "manual",
      "localizations": {
