        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 GitHub Copilot authentication started!\n\nPlease visit github.com/login/device and enter the code shown.\n\nThe app will automatically detect your credentials."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 ¡Autenticación de GitHub Copilot iniciada!\n\nPor favor visita github.com/login/device e ingresa el código mostrado.\n\nLa aplicación detectará automáticamente tus credenciales."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 GitHub Copilot 身份验证已开始！\n\n请访问 github.com/login/device 并输入显示的代码。\n\n应用将自动检测您的凭据。"
