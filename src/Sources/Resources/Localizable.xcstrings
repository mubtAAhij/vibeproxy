    "provider.gemini.help": {
      "comment": "Help text for Gemini provider",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Note: If you're an existing Gemini user with multiple projects, authentication will use your default project. Set your desired project as default in Google AI Studio before connecting."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Nota: Si eres un usuario existente de Gemini con múltiples proyectos, la autenticación utilizará tu proyecto predeterminado. Establece tu proyecto deseado como predeterminado en Google AI Studio antes de conectarte."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 注意：如果您是拥有多个项目的现有 Gemini 用户，身份验证将使用您的默认项目。请在连接前于 Google AI Studio 中将所需项目设置为默认项目。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Remarque : Si vous êtes un utilisateur Gemini existant avec plusieurs projets, l'authentification utilisera votre projet par défaut. Définissez le projet souhaité par défaut dans Google AI Studio avant de vous connecter."
          }
        }
      }
    },
    "provider.copilot.help": {
      "comment": "Help text for GitHub Copilot provider",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Copilot provides access to Claude, GPT, Gemini and other models via your Copilot subscription."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Copilot proporciona acceso a Claude, GPT, Gemini y otros modelos a través de tu suscripción de Copilot."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Copilot 通过您的 Copilot 订阅提供对 Claude、GPT、Gemini 及其他模型的访问。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Copilot fournit un accès à Claude, GPT, Gemini et d'autres modèles via votre abonnement Copilot."
          }
        }
      }
    },
    "provider.zai.help": {
      "comment": "Help text for Z.AI provider",
