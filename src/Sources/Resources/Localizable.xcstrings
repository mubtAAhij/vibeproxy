          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "请求行无效"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligne de requête invalide"
          }
        }
      }
    },
    "proxy.error.invalid-request-format": {
      "comment": "Error when HTTP request format is malformed",
