    "tunnel-manager.cloudflared.not-installed.title": {
      "comment": "Alert title when cloudflared is not installed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared Not Installed"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared No Instalado"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared 未安装"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared non installé"
          }
        }
      }
    },
    "tunnel-manager.cloudflared.not-installed.message": {
      "comment": "Instructions for installing cloudflared",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To expose your server to the internet, you need to install cloudflared.\n\nInstall via Homebrew:\nbrew install cloudflared\n\nOr download from:\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "        Para exponer tu servidor a internet, necesitas instalar cloudflared.\n        \n        Instalar vía Homebrew:\n        brew install cloudflared\n        \n        O descargar desde:\n        https://github.com/cloudflare/cloudflared/releases\n"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "        要将您的服务器暴露到互联网，您需要安装 cloudflared。\n        \n        通过 Homebrew 安装：\n        brew install cloudflared\n        \n        或从以下地址下载：\n        https://github.com/cloudflare/cloudflared/releases\n"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "        Pour exposer votre serveur à Internet, vous devez installer cloudflared.\n        \n        Installation via Homebrew :\n        brew install cloudflared\n        \n        Ou téléchargez depuis :\n        https://github.com/cloudflare/cloudflared/releases\n"
          }
        }
      }
    },
    "tunnel-manager.cloudflared.copy-install-command": {
      "comment": "Button to copy brew install command",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy Install Command"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiar Comando de Instalación"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "复制安装命令"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Copier la commande d'installation"
          }
        }
      }
    },
    "server-manager.error.resource-path-not-found": {
      "comment": "Error when app resource path cannot be found",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not find resource path"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo encontrar la ruta del recurso"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无法找到资源路径"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de trouver le chemin de la ressource"
          }
        }
      }
    },
    "server-manager.error.binary-not-found": {
      "comment": "Error when binary file is not found at path",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Binary not found at %@"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Binario no encontrado en \\(bundledPath)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "二进制文件未找到，路径：\\(bundledPath)"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Binaire introuvable à l'emplacement \\(bundledPath)"
          }
        }
      }
    },
    "server-manager.auth.github-code-copied": {
      "comment": "Success message when GitHub auth code is copied to clipboard",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\n\n📋 Code copied to clipboard:\n\n%@\n\nJust paste it in the browser!\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\\n\\n📋 Código copiado al portapapeles:\\n\\n\\(code)\\n\\n¡Solo pégalo en el navegador!\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\\n\\n📋 代码已复制到剪贴板：\\n\\n\\(code)\\n\\n只需将其粘贴到浏览器中即可！\\n\\n应用将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\\n\\n📋 Code copié dans le presse-papiers :\\n\\n\\(code)\\n\\nCollez-le simplement dans le navigateur !\\n\\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "server-manager.auth.github-browser-opened": {
      "comment": "Success message when GitHub auth browser opens without code extraction",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\n\nCheck your terminal or the opened browser for the device code.\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\\n\\nVerifica tu terminal o el navegador abierto para ver el código del dispositivo.\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\n\n请在终端或已打开的浏览器中查看设备代码。\n\n应用将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\\n\\nVérifiez votre terminal ou le navigateur ouvert pour le code d'appareil.\\n\\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "server-manager.auth.browser-opened": {
      "comment": "Generic success message when auth browser opens",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for authentication.\n\nPlease complete the login in your browser.\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación.\\n\\nPor favor completa el inicio de sesión en tu navegador.\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行身份验证。\n\n请在浏览器中完成登录。\n\n应用将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification.\\n\\nVeuillez terminer la connexion dans votre navigateur.\\n\\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "server-manager.error.auth-failed-unexpectedly": {
      "comment": "Error when auth process fails without error message",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentication process failed unexpectedly"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El proceso de autenticación falló inesperadamente"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证过程意外失败"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le processus d'authentification a échoué de manière inattendue"
          }
        }
      }
    },
    "server-manager.error.auth-process-start-failed": {
      "comment": "Error when auth process fails to start",
      "extractionState": "manual",
