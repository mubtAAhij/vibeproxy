          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的请求行"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligne de requête invalide"
          }
        }
      }
    },
    "proxy.error.invalid-request-format": {
      "comment": "HTTP error for malformed request line format",
