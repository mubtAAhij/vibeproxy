        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide - aucun séparateur de corps"
          }
        }
      }
    },
    "proxy.error.ampcode-gateway": {
      "comment": "HTTP 502 error when connection to ampcode.com fails",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bad Gateway - Could not connect to ampcode.com"
