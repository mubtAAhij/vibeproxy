    "settings.auth.success.claude": {
      "comment": "Success message for Claude authentication",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for Claude Code authentication.\n\nPlease complete the login in your browser.\n\nThe app will automatically detect your credentials."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Se abrió el navegador para autenticación de Claude Code.\n\nPor favor completa el inicio de sesión en tu navegador.\n\nLa aplicación detectará automáticamente tus credenciales."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 Claude Code 身份验证。\n\n请在浏览器中完成登录。\n\n应用将自动检测您的凭据。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification Claude Code.\n\nVeuillez vous connecter dans votre navigateur.\n\nL'application détectera automatiquement vos identifiants."
          }
        }
      }
    },
