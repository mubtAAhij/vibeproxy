    "github_auth_browser_opened_code_copied": {
      "comment": "Success message for GitHub Copilot auth with device code",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\n\n📋 Code copied to clipboard:\n\n%@\n\nJust paste it in the browser!\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\n\n📋 Código copiado al portapapeles:\n\n%@\n\n¡Solo pégalo en el navegador!\n\nLa aplicación detectará automáticamente cuando estés autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\n\n📋 代码已复制到剪贴板:\n\n%@\n\n请在浏览器中粘贴！\n\n应用会自动检测您何时完成身份验证。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\n\n📋 Code copié dans le presse-papiers :\n\n%@\n\nCollez-le simplement dans le navigateur !\n\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "github_auth_browser_opened_check_terminal": {
      "comment": "Success message for GitHub Copilot auth without code extraction",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\n\nCheck your terminal or the opened browser for the device code.\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\n\nRevisa tu terminal o el navegador abierto para ver el código de dispositivo.\n\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\n\n请在终端或已打开的浏览器中查看设备代码。\n\n应用将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\n\nConsultez votre terminal ou le navigateur ouvert pour le code d'appareil.\n\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "auth_browser_opened_complete_login": {
      "comment": "Generic success message for authentication",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for authentication.\n\nPlease complete the login in your browser.\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación.\n\nPor favor completa el inicio de sesión en tu navegador.\n\nLa aplicación detectará automáticamente cuando estés autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行身份验证。\n\n请在浏览器中完成登录。\n\n应用会在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification.\n\nVeuillez terminer la connexion dans votre navigateur.\n\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
