        }
      }
    },
    "settings.auth-result.no-output": {
      "comment": "Fallback message when authentication fails with no output",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No output from authentication process"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Falló la autenticación. Por favor, verifica si se abrió el navegador e intenta de nuevo.\\n\\nDetalles: \\(output.isEmpty ? \\\"No hay información del proceso de autenticación\\\" : output)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证失败。请检查浏览器是否已打开，然后重试。\\n\\n详细信息：\\(output.isEmpty ? \\\"身份验证过程无输出\\\" : output)"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "L'authentification a échoué. Veuillez vérifier que le navigateur s'est ouvert et réessayer.\\n\\nDétails : \\(output.isEmpty ? \\\"Aucune sortie du processus d'authentification\\\" : output)"
          }
        }
      }
    },
    "settings.auth-result.claude-success": {
