{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "thinking-proxy.error.invalid-request": {
      "comment": "Error message when request encoding is invalid",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitud inválida"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效请求"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Requête invalide"
          }
        }
      }
    },
    "thinking-proxy.error.invalid-request-line": {
      "comment": "Error message when HTTP request line is missing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request line"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Línea de solicitud inválida"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的请求行"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligne de requête invalide"
          }
        }
      }
    },
    "thinking-proxy.error.invalid-request-format": {
      "comment": "Error message when HTTP request format is incorrect",
      "extractionState": "manual",
      "localizations": {
