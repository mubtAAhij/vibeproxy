    "settings.auth.success.gemini": {
      "comment": "Success message for Gemini authentication with multi-project note",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for Gemini authentication.\n\nPlease complete the login in your browser.\n\n⚠️ Note: If you have multiple projects, the default project will be used."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de Gemini.\n\nPor favor completa el inicio de sesión en tu navegador.\n\n⚠️ Nota: Si tienes múltiples proyectos, se usará el proyecto predeterminado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 Gemini 身份验证。\n\n请在浏览器中完成登录。\n\n⚠️ 注意：如果您有多个项目，将使用默认项目。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification Gemini.\n\nVeuillez terminer la connexion dans votre navigateur.\n\n⚠️ Remarque : Si vous avez plusieurs projets, le projet par défaut sera utilisé."
          }
        }
      }
    },
