  "strings": {
    "proxy.error.invalid-request": {
      "comment": "HTTP 400 error for malformed request data",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitud no válida"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效请求"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Requête invalide"
          }
        }
      }
    },
    "proxy.error.invalid-request-line": {
      "comment": "HTTP 400 error for missing request line",
      "extractionState": "manual",
      "localizations": {
