{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "proxy.error.invalid-request": {
      "comment": "Error when HTTP request data cannot be decoded",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效请求"
          }
        }
      }
    },
    "proxy.error.invalid-request-line": {
      "comment": "Error when HTTP request line is missing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request line"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Línea de solicitud inválida"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的请求行"
          }
        }
      }
    },
    "proxy.error.invalid-request-format": {
      "comment": "Error when HTTP request format is malformed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request format"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato de solicitud inválido"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide"
          }
        }
      }
    },
    "proxy.error.no-body-separator": {
      "comment": "Error when HTTP request is missing header/body separator",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request format - no body separator"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的请求格式 - 缺少正文分隔符"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide - pas de séparateur de corps"
          }
        }
      }
    },
    "proxy.error.ampcode-connection-failed": {
      "comment": "Error when proxy cannot connect to ampcode.com",
