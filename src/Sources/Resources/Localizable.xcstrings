    "tunnel.cloudflared-not-installed.title": {
      "comment": "Alert title when cloudflared is not installed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared Not Installed"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared no instalado"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared 未安装"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared non installé"
          }
        }
      }
    },
    "tunnel.cloudflared-not-installed.message": {
      "comment": "Instructions for installing cloudflared via Homebrew or direct download",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To expose your server to the internet, you need to install cloudflared.\n\nInstall via Homebrew:\nbrew install cloudflared\n\nOr download from:\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "        Para exponer tu servidor a internet, necesitas instalar cloudflared.\n        \n        Instalar vía Homebrew:\n        brew install cloudflared\n        \n        O descargar desde:\n        https://github.com/cloudflare/cloudflared/releases\n"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "        要将您的服务器暴露到互联网，您需要安装 cloudflared。\n        \n        通过 Homebrew 安装：\n        brew install cloudflared\n        \n        或从以下地址下载：\n        https://github.com/cloudflare/cloudflared/releases\n"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "        Pour exposer votre serveur sur internet, vous devez installer cloudflared.\n        \n        Installation via Homebrew :\n        brew install cloudflared\n        \n        Ou téléchargez depuis :\n        https://github.com/cloudflare/cloudflared/releases\n"
          }
        }
      }
    },
    "tunnel.cloudflared-not-installed.copy-command": {
      "comment": "Button to copy install command to clipboard",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy Install Command"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiar comando de instalación"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "复制安装命令"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Copier la commande d'installation"
          }
        }
      }
    },
