        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide"
          }
        }
      }
    },
    "proxy.error.no-body-separator": {
      "comment": "HTTP 400 error when body separator is missing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
