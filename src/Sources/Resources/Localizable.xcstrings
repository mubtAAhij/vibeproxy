    "tunnel.cloudflared-not-installed.title": {
      "comment": "Alert title when cloudflared is not installed on the system",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared Not Installed"
          }
        }
      }
