              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "\\(accounts.count) 个已连接账户"
                }
              }
            }
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "\\(accounts.count) compte\\(accounts.count == 1 ? \\\"\\\" : \\\"s\\\") connecté\\(accounts.count == 1 ? \\\"\\\" : \\\"s\\\")"
          },
          "variations": {
