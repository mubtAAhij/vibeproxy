            "value": "Error Interno del Servidor"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "内部服务器错误"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Erreur interne du serveur"
          }
        }
      }
    },
    "http.error.bad-gateway": {
      "comment": "HTTP 502 error when the proxy cannot connect to the target server",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bad Gateway"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Puerta de enlace incorrecta"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "错误网关"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Passerelle incorrecte"
          }
        }
      }
    },
    "tunnel.cloudflared-not-installed.title": {
      "comment": "Alert title when cloudflared is not installed on the system",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared Not Installed"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared No Instalado"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared 未安装"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared non installé"
          }
        }
      }
    },
    "tunnel.cloudflared-not-installed.message": {
      "comment": "Instructions for installing cloudflared via Homebrew or from GitHub releases",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To expose your server to the internet, you need to install cloudflared.\n\nInstall via Homebrew:\nbrew install cloudflared\n\nOr download from:\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "        Para exponer tu servidor a internet, necesitas instalar cloudflared.\n        \n        Instalar vía Homebrew:\n        brew install cloudflared\n        \n        O descargar desde:\n        https://github.com/cloudflare/cloudflared/releases\n"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "        要将您的服务器暴露到互联网，您需要安装 cloudflared。\n        \n        通过 Homebrew 安装：\n        brew install cloudflared\n        \n        或从以下地址下载：\n        https://github.com/cloudflare/cloudflared/releases\n"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "        Pour exposer votre serveur à Internet, vous devez installer cloudflared.\n        \n        Installer via Homebrew :\n        brew install cloudflared\n        \n        Ou télécharger depuis :\n        https://github.com/cloudflare/cloudflared/releases\n"
          }
        }
      }
    },
    "tunnel.cloudflared-not-installed.copy-button": {
      "comment": "Button to copy the brew install command to clipboard",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy Install Command"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiar Comando de Instalación"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "复制安装命令"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Copier la commande d'installation"
          }
        }
      }
    },
    "tunnel.cloudflared-not-installed.cancel-button": {
      "comment": "Button to dismiss the cloudflared installation instructions alert",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        }
      }
    },
    "server.error.no-resource-path": {
      "comment": "Error when the app bundle's resource path cannot be determined",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not find resource path"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo encontrar la ruta del recurso"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到资源路径"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de trouver le chemin de la ressource"
          }
        }
      }
    },
    "server.error.binary-not-found": {
      "comment": "Error when the CLI binary is not found at the expected path",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Binary not found at %@"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Binario no encontrado en \\(bundledPath)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "在 \\(bundledPath) 未找到二进制文件"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Binaire introuvable à \\(bundledPath)"
          }
        }
      }
    },
    "auth.copilot.code-extracted": {
      "comment": "Success message when GitHub Copilot device code is extracted and copied to clipboard",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\n📋 Code copied to clipboard:\\n\\n%@\\n\\nJust paste it in the browser!\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\\n\\n📋 Código copiado al portapapeles:\\n\\n\\(code)\\n\\n¡Solo pégalo en el navegador!\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\\n\\n📋 代码已复制到剪贴板：\\n\\n\\(code)\\n\\n只需将其粘贴到浏览器中即可！\\n\\n应用将自动检测您的身份验证状态。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\\n\\n📋 Code copié dans le presse-papiers :\\n\\n\\(code)\\n\\nCollez-le simplement dans le navigateur !\\n\\nL'application détectera automatiquement votre authentification."
          }
        }
      }
    },
    "auth.copilot.code-not-extracted": {
      "comment": "Fallback message when GitHub Copilot device code cannot be extracted automatically",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\\n\\nCheck your terminal or the opened browser for the device code.\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\\n\\nRevisa tu terminal o el navegador abierto para ver el código de dispositivo.\\n\\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\\n\\n请在终端或已打开的浏览器中查看设备代码。\\n\\n应用将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\\n\\nConsultez votre terminal ou le navigateur ouvert pour le code de l'appareil.\\n\\nL'application détectera automatiquement votre authentification."
          }
        }
      }
    },
    "auth.generic.browser-opened": {
      "comment": "Generic authentication success message when browser is opened",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for authentication.\\n\\nPlease complete the login in your browser.\\n\\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación.\\n\\nPor favor completa el inicio de sesión en tu navegador.\\n\\nLa aplicación detectará automáticamente cuando estés autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行身份验证。\\n\\n请在浏览器中完成登录。\\n\\n应用将自动检测您的登录状态。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification.\\n\\nVeuillez compléter la connexion dans votre navigateur.\\n\\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "auth.error.process-failed": {
      "comment": "Error when authentication process fails without specific error details",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentication process failed unexpectedly"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El proceso de autenticación falló inesperadamente"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证过程意外失败"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le processus d'authentification a échoué de manière inattendue"
          }
        }
      }
    },
    "auth.error.failed-to-start": {
      "comment": "Error when authentication process cannot be started",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to start auth process: %@"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo iniciar el proceso de autenticación: \\(error.localizedDescription)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无法启动认证流程：\\(error.localizedDescription)"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec du démarrage du processus d'authentification : \\(error.localizedDescription)"
          }
        }
      }
    },
    "auth.error.failed-to-create-auth-dir": {
      "comment": "Error when the authentication directory cannot be created",
      "extractionState": "manual",
