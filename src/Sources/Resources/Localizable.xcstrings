{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "http.error.invalid-request": {
      "comment": "HTTP 400 error when request data cannot be decoded as UTF-8",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitud inválida"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效请求"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Requête invalide"
          }
        }
      }
    },
    "http.error.invalid-request-line": {
      "comment": "HTTP 400 error when the request line is missing or malformed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request line"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Línea de solicitud inválida"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "请求行无效"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligne de requête invalide"
          }
        }
      }
    },
    "http.error.invalid-request-format": {
      "comment": "HTTP 400 error when the request line doesn't have the required three parts",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request format"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato de solicitud inválido"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "请求格式无效"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide"
          }
        }
      }
    },
    "http.error.no-body-separator": {
      "comment": "HTTP 400 error when the request is missing the header/body separator",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request format - no body separator"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato de solicitud inválido - sin separador de cuerpo"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "请求格式无效 - 缺少正文分隔符"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Format de requête invalide - pas de séparateur de corps"
          }
        }
      }
    },
    "http.error.ampcode-gateway": {
      "comment": "HTTP 502 error when the proxy cannot connect to ampcode.com",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bad Gateway - Could not connect to ampcode.com"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Puerta de enlace incorrecta - No se pudo conectar a ampcode.com"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "网关错误 - 无法连接到 ampcode.com"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Passerelle incorrecte - Impossible de se connecter à ampcode.com"
          }
        }
      }
    },
    "http.error.vercel-gateway": {
      "comment": "HTTP 502 error when the proxy cannot connect to Vercel AI Gateway",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bad Gateway - Could not connect to Vercel AI Gateway"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Puerta de enlace incorrecta - No se pudo conectar con Vercel AI Gateway"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "错误网关 - 无法连接到 Vercel AI Gateway"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Passerelle incorrecte - Impossible de se connecter à Vercel AI Gateway"
          }
        }
      }
    },
    "http.error.internal-server-error": {
      "comment": "HTTP 500 error for generic internal server errors",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Internal Server Error"
          }
        },
        "es-419": {
          "stringUnit": {
