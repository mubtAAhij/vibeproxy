            "value": "Cloudflared Not Installed"
          }
        }
      }
    },
    "tunnel.cloudflared.not-installed.message": {
      "comment": "Instructions for installing cloudflared",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To expose your server to the internet, you need to install cloudflared.\n\nInstall via Homebrew:\nbrew install cloudflared\n\nOr download from:\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        }
      }
    },
    "tunnel.cloudflared.copy-command": {
      "comment": "Button to copy the cloudflared install command",
