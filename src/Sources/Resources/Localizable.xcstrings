    "tunnel.cloudflared-not-installed.title": {
      "comment": "Alert title when cloudflared is not installed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared Not Installed"
          }
        }
      }
    },
    "tunnel.cloudflared-not-installed.message": {
      "comment": "Instructions for installing cloudflared",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To expose your server to the internet, you need to install cloudflared.\n\nInstall via Homebrew:\nbrew install cloudflared\n\nOr download from:\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Para exponer tu servidor a internet, necesitas instalar cloudflared.\n\nInstalar vía Homebrew:\nbrew install cloudflared\n\nO descargar desde:\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "要将您的服务器暴露到互联网，您需要安装 cloudflared。\n\n通过 Homebrew 安装：\nbrew install cloudflared\n\n或从以下地址下载：\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour exposer votre serveur sur Internet, vous devez installer cloudflared.\n\nInstallation via Homebrew :\nbrew install cloudflared\n\nOu téléchargez depuis :\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        }
      }
    },
    "tunnel.cloudflared-not-installed.copy-command": {
      "comment": "Button to copy brew install command",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy Install Command"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiar Comando de Instalación"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "复制安装命令"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Copier commande d'installation"
          }
        }
      }
    },
    "tunnel.cloudflared-not-installed.cancel": {
      "comment": "Button to dismiss alert",
