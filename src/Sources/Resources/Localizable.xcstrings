    "auth.copilot.success-with-code": {
      "comment": "Success message for Copilot auth with device code",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\n\n📋 Code copied to clipboard:\n\n%@\n\nJust paste it in the browser!\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\n\n📋 Código copiado al portapapeles:\n\n%@\n\n¡Solo pégalo en el navegador!\n\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\n\n📋 代码已复制到剪贴板：\n\n%@\n\n只需在浏览器中粘贴即可！\n\n应用程序将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\n\n📋 Code copié dans le presse-papiers :\n\n%@\n\nCollez-le simplement dans le navigateur !\n\nL'application détectera automatiquement votre authentification."
          }
        }
      }
    },
    "auth.copilot.success-no-code": {
      "comment": "Success message for Copilot auth without extracted code",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\n\nCheck your terminal or the opened browser for the device code.\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Se abrió el navegador para la autenticación de GitHub.\n\nRevisa tu terminal o el navegador abierto para ver el código del dispositivo.\n\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\n\n请检查您的终端或已打开的浏览器以获取设备代码。\n\n应用程序将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\n\nConsultez votre terminal ou le navigateur ouvert pour le code de l'appareil.\n\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "auth.generic.success": {
      "comment": "Generic success message for OAuth authentication",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for authentication.\n\nPlease complete the login in your browser.\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación.\n\nPor favor completa el inicio de sesión en tu navegador.\n\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行身份验证。\n\n请在浏览器中完成登录。\n\n应用将在您完成验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification.\n\nVeuillez vous connecter dans votre navigateur.\n\nL'application détectera automatiquement votre authentification."
          }
        }
      }
    },
    "auth.error.unexpected-failure": {
      "comment": "Error when auth process fails without specific error message",
      "extractionState": "manual",
