    "server.error.resource-path-not-found": {
      "comment": "Error when app bundle resource path is missing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not find resource path"
          }
        },
        "es-419": {
