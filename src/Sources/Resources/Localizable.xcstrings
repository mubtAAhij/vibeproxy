    "settings.gemini.help": {
      "comment": "Help text for Gemini service about project selection",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Note: If you're an existing Gemini user with multiple projects, authentication will use your default project. Set your desired project as default in Google AI Studio before connecting."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Nota: Si ya eres usuario de Gemini con múltiples proyectos, la autenticación usará tu proyecto predeterminado. Configura el proyecto deseado como predeterminado en Google AI Studio antes de conectarte."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 注意：如果您是拥有多个项目的 Gemini 现有用户，身份验证将使用您的默认项目。请在连接前先在 Google AI Studio 中将所需项目设为默认项目。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Note : Si vous êtes déjà utilisateur Gemini avec plusieurs projets, l'authentification utilisera votre projet par défaut. Définissez le projet souhaité comme projet par défaut dans Google AI Studio avant de vous connecter."
          }
        }
      }
    },
    "settings.copilot.help": {
      "comment": "Help text for GitHub Copilot service",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Copilot provides access to Claude, GPT, Gemini and other models via your Copilot subscription."
