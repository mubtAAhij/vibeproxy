    "tunnel-manager.cloudflared-not-installed": {
      "comment": "Alert title when cloudflared is not found",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared Not Installed"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared No Instalado"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared 未安装"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflared non installé"
          }
        }
      }
    },
    "tunnel-manager.cloudflared-install-instructions": {
      "comment": "Alert message with cloudflared installation instructions",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To expose your server to the internet, you need to install cloudflared.\n\nInstall via Homebrew:\nbrew install cloudflared\n\nOr download from:\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Para exponer tu servidor a internet, necesitas instalar cloudflared.\n\nInstalar vía Homebrew:\nbrew install cloudflared\n\nO descargar desde:\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "要将您的服务器暴露到互联网，您需要安装 cloudflared。\n\n通过 Homebrew 安装：\nbrew install cloudflared\n\n或从以下地址下载：\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour exposer votre serveur à Internet, vous devez installer cloudflared.\n\nInstallation via Homebrew :\nbrew install cloudflared\n\nOu télécharger depuis :\nhttps://github.com/cloudflare/cloudflared/releases"
          }
        }
      }
    },
    "tunnel-manager.copy-install-command": {
      "comment": "Button to copy cloudflared install command",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy Install Command"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiar Comando de Instalación"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "复制安装命令"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Copier la commande d'installation"
          }
        }
      }
    },
