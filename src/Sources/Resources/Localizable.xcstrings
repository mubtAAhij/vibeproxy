    "vercel_ai_gateway_help": {
      "comment": "Help text for Vercel AI Gateway",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Route Claude requests through Vercel AI Gateway for safer access to your Claude Max subscription"
