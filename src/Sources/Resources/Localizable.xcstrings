{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "http.error.invalid-request": {
      "comment": "HTTP 400 error when request data cannot be decoded as UTF-8",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request"
          }
        }
      }
    },
    "http.error.invalid-request-line": {
      "comment": "HTTP 400 error when the request line is missing or malformed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid request line"
          }
        }
      }
    },
    "http.error.invalid-request-format": {
      "comment": "HTTP 400 error when the request line doesn't have the required three parts",
