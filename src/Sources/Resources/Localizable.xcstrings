    "server.error.resource-path-not-found": {
      "comment": "Error when app bundle resource path cannot be located",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not find resource path"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo encontrar la ruta del recurso"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到资源路径"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de trouver le chemin de la ressource"
          }
        }
      }
    },
    "server.error.binary-not-found": {
      "comment": "Error when CLI binary is missing from expected path",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Binary not found at %@"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Binario no encontrado en %@"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "未在 %@ 找到二进制文件"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Binaire introuvable à %@"
          }
        }
      }
    },
    "auth.copilot.success-with-code": {
      "comment": "Success message when Copilot device code is copied to clipboard",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\n\n📋 Code copied to clipboard:\n\n%@\n\nJust paste it in the browser!\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\n\n📋 Código copiado al portapapeles:\n\n%@\n\n¡Solo pégalo en el navegador!\n\nLa aplicación detectará automáticamente cuando estés autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\n\n📋 代码已复制到剪贴板：\n\n%@\n\n只需将其粘贴到浏览器中即可！\n\n应用程序将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\n\n📋 Code copié dans le presse-papiers :\n\n%@\n\nCollez-le simplement dans le navigateur !\n\nL'application détectera automatiquement votre authentification."
          }
        }
      }
    },
    "auth.copilot.success-no-code": {
      "comment": "Success message when Copilot browser opens but device code couldn't be extracted",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for GitHub authentication.\n\nCheck your terminal or the opened browser for the device code.\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navegador abierto para autenticación de GitHub.\n\nRevisa tu terminal o el navegador abierto para ver el código del dispositivo.\n\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行 GitHub 身份验证。\n\n请在终端或已打开的浏览器中查看设备代码。\n\n应用将在您完成身份验证后自动检测。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification GitHub.\n\nVérifiez votre terminal ou le navigateur ouvert pour le code de l'appareil.\n\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "auth.generic.success": {
      "comment": "Generic success message when browser opens for authentication",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Browser opened for authentication.\n\nPlease complete the login in your browser.\n\nThe app will automatically detect when you're authenticated."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Se abrió el navegador para autenticación.\n\nPor favor, completa el inicio de sesión en tu navegador.\n\nLa aplicación detectará automáticamente cuando te hayas autenticado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 已打开浏览器进行身份验证。\n\n请在浏览器中完成登录。\n\n应用会自动检测您的登录状态。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "🌐 Navigateur ouvert pour l'authentification.\n\nVeuillez terminer la connexion dans votre navigateur.\n\nL'application détectera automatiquement lorsque vous serez authentifié."
          }
        }
      }
    },
    "auth.error.process-failed": {
      "comment": "Error when authentication process exits without clear error message",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentication process failed unexpectedly"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El proceso de autenticación falló inesperadamente"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证过程意外失败"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le processus d'authentification a échoué de manière inattendue"
          }
        }
      }
    },
    "auth.error.start-failed": {
      "comment": "Error when authentication process cannot be started",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to start auth process: %@"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo iniciar el proceso de autenticación: %@"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "启动认证过程失败：%@"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec du démarrage du processus d'authentification : %@"
          }
        }
      }
    },
    "auth.error.directory-create-failed": {
      "comment": "Error when authentication directory cannot be created",
      "extractionState": "manual",
      "localizations": {
