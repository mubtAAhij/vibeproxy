          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的请求行"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligne de requête non valide"
          }
        }
      }
    },
    "proxy.error.invalid-request-format": {
      "comment": "HTTP error when request doesn't have method, path, and version",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
