    "settings.antigravity.help": {
      "comment": "Help text for Antigravity service",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity provides OAuth-based access to various AI models including Gemini and Claude. One login gives you access to multiple AI services."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity proporciona acceso basado en OAuth a varios modelos de IA, incluyendo Gemini y Claude. Un solo inicio de sesión te da acceso a múltiples servicios de IA."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity 通过 OAuth 提供对多种 AI 模型的访问，包括 Gemini 和 Claude。只需一次登录即可使用多个 AI 服务。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity fournit un accès basé sur OAuth à différents modèles d'IA, dont Gemini et Claude. Une seule connexion vous donne accès à plusieurs services d'IA."
          }
        }
      }
    },
